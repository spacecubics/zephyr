config XLNX_SDHC
	bool "xlnx sdhc driver"
	default y
	depends on DT_HAS_XLNX_VERSAL_8_9A_ENABLED
	select SDHC_SUPPORTS_NATIVE_MODE
	select SDHC_SUPPORTS_UHS
	select EVENTS
	select CLOCK_CONTROL
	select CLOCK_CONTROL_FIXED_RATE_CLOCK
	help
	  Enable xilinx SD/EMMC host controller driver

if XLNX_SDHC

# sdhc needs 32 byte aligned buffers
config SDHC_BUFFER_ALIGNMENT
	default 32

config HOST_ADMA2_DESC_SIZE
	int "Max descriptor SIZE"
	default 32
	help
	  Set max number of descriptors supported

config SDHC_XLNX_DMA_BOUNCE
	bool "Enable OCM bounce buffer for Xilinx SDHC DMA"
	default y
	depends on DT_HAS_XLNX_VERSAL_OCM_ENABLED
	help
	  Enable DMA bounce buffering using OCM for Xilinx SDHC.
	  If a buffer passed to the SDHC driver is outside the OCM range,
	  a bounce buffer in OCM is used automatically.

config SDHC_XLNX_BOUNCE_SIZE
	int "Bounce buffer size (bytes)"
	default 65536
	depends on SDHC_XLNX_DMA_BOUNCE
	help
	  Set the size of the per-controller bounce buffer in OCM.
	  Must be a multiple of 512 for SD/eMMC block transfers.
	  Should be at least the maximum transfer size expected.

config SDHC_XLNX_BOUNCE_WARN
	bool "Warn when SDHC DMA buffer is outside OCM"
	default y
	depends on SDHC_XLNX_DMA_BOUNCE

endif
